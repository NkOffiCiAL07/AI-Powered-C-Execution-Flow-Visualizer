# Google Gemini API key — required for AI Insights (Explain Code) feature
# Get yours free at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth — required for Sign In with Google
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:8000/auth/google/callback to Authorized redirect URIs
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT signing secret — change this to a long random string in production
JWT_SECRET=change-this-to-a-random-secret-in-production

# OAuth callback URI (default: http://localhost:8000/auth/google/callback)
# OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Frontend origin for postMessage target (default: http://localhost:3000)
# FRONTEND_ORIGIN=http://localhost:3000

# MongoDB connection URI — optional, omit to use in-memory session storage
# MONGO_URI=mongodb://localhost:27017

# CORS allowed origins — comma-separated list of frontend origins (default: localhost:3000)
# In production set this to your deployed frontend URL(s)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.example.com
